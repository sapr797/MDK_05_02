        }, f, ensure_ascii=False, indent=2)


def main():
    """Демонстрация работы"""
    
    # Создаём тестовые файлы
    create_sample_files()
    
    print("=" * 70)
    print("ДЕМОНСТРАЦИЯ ПАТТЕРНОВ FACTORY METHOD И ADAPTER")
    print("=" * 70)
    
    # Создаём процессор документов
    processor = DocumentProcessor()
    
    print(f"\nПоддерживаемые форматы: {processor.get_supported_formats()}")
    
    # Обработка разных типов документов
    test_files = [
        ("sample.txt", "TXT"),
        ("sample.json", "JSON"),
    ]
    
    print("\n" + "-" * 70)
    print("ОБРАБОТКА ДОКУМЕНТОВ")
    print("-" * 70)
    
    for file_path, expected_format in test_files:
        if not os.path.exists(file_path):
            print(f"Файл {file_path} не найден, пропускаем")
            continue
        
        try:
            print(f"\nОбработка: {file_path}")
            doc = processor.process_document(file_path)
            print(f"  Результат: {doc}")
            print(f"  Метаданные: {doc.title} ({doc.author})")
            print(f"  Длина содержимого: {len(doc.content)} символов")
        except ValueError as e:
            print(f"  Ошибка: {e}")
    
    # Демонстрация расширяемости (новая фабрика)
    print("\n" + "-" * 70)
    print("РАСШИРЕНИЕ СИСТЕМЫ (НОВЫЙ ФОРМАТ)")
    print("-" * 70)
    
    # Регистрируем новую фабрику для JSON
    processor.register_factory("json", JSONParserFactory())
    
    print(f"Обновлённые форматы: {processor.get_supported_formats()}")
    
    # Обрабатываем JSON
    if os.path.exists("sample.json"):
        print("\nОбработка JSON файла:")
        doc = processor.process_document("sample.json")
        print(f"  Результат: {doc}")
    
    # Демонстрация работы адаптера
    print("\n" + "-" * 70)
    print("РАБОТА АДАПТЕРА (PDF)")
    print("-" * 70)
    
    # Создаём PDF парсер через фабрику
    pdf_factory = PDFParserFactory("LICENSE_XYZ_2024")
    pdf_parser = pdf_factory.create_parser()
    
    print("\nСоздан PDF парсер через адаптер:")
    print(f"  Тип парсера: {pdf_parser.__class__.__name__}")
    print(f"  Внутри используется: {pdf_parser._external.__class__.__name__}")
    
    print("\n" + "=" * 70)
    print("ДЕМОНСТРАЦИЯ ЗАВЕРШЕНА")
    print("=" * 70)
    
    # Очистка (опционально)
