#!/usr/bin/env python3
"""
Модуль для обработки документов с использованием паттернов
Factory Method и Adapter.
"""

from abc import ABC, abstractmethod
from typing import Dict, Any, List, Optional
from dataclasses import dataclass
from datetime import datetime
import os


# ============================================================
# ЧАСТЬ 1: АДАПТЕР (Adapter Pattern)
# ============================================================

# ---------- СТОРОННЯЯ БИБЛИОТЕКА (несовместимый интерфейс) ----------
class ExternalPDFProcessor:
    """
    Сторонняя библиотека для работы с PDF.
    Имеет неудобный для нас интерфейс.
    """
    
    def __init__(self, license_key: str):
        self.license_key = license_key
        self._initialized = False
    
    def initialize(self) -> bool:
        """Инициализация библиотеки"""
        if self.license_key:
            self._initialized = True
            print(f"[ExternalPDF] Инициализирована с ключом {self.license_key[:5]}...")
        return self._initialized
    
    def extract_content_raw(self, file_path: str) -> bytes:
        """Извлечение сырого содержимого"""
        print(f"[ExternalPDF] Извлечение сырых данных из {file_path}")
        return b"Raw PDF content"
    
    def parse_document_structure(self, raw_data: bytes) -> Dict:
        """Парсинг структуры документа"""
        print(f"[ExternalPDF] Парсинг структуры документа")
        return {
            "pages": 5,
            "metadata": {"author": "External Author", "title": "External Title"},
            "text": "Extracted text from PDF using external library"
        }
    
    def get_text_by_page(self, structured_data: Dict, page_num: int) -> str:
        """Получение текста по странице"""
        return f"Page {page_num} content from external library"


# ---------- НАШ ЦЕЛЕВОЙ ИНТЕРФЕЙС ----------
class DocumentParser(ABC):
    """Целевой интерфейс для парсинга документов"""
    
    @abstractmethod
    def parse(self, file_path: str) -> 'Document':
        pass
    
    @abstractmethod
    def get_metadata(self) -> Dict[str, Any]:
        pass
    
    @abstractmethod
    def get_text(self) -> str:
        pass


@dataclass
class Document:
    """Модель документа"""
    title: str
    author: str
    content: str
    pages: int
    format: str
    created_at: datetime = None
    
    def __post_init__(self):
        if self.created_at is None:
            self.created_at = datetime.now()
    
    def __str__(self) -> str:
        return f"Document({self.format}): {self.title} by {self.author}, {self.pages} pages"


# ---------- АДАПТЕР ДЛЯ PDF ----------
class PDFAdapter(DocumentParser):
    """Адаптер для сторонней PDF библиотеки"""
    
    def __init__(self, external_processor: ExternalPDFProcessor):
        self._external = external_processor
        self._current_document: Optional[Document] = None
        self._raw_data: Optional[bytes] = None
        self._structured_data: Optional[Dict] = None
    
    def parse(self, file_path: str) -> Document:
        """Адаптация внешнего интерфейса к нашему"""
        # Шаг 1: инициализация
        if not self._external._initialized:
            self._external.initialize()
        
        # Шаг 2: извлечение сырых данных
        self._raw_data = self._external.extract_content_raw(file_path)
        
        # Шаг 3: парсинг структуры
        self._structured_data = self._external.parse_document_structure(self._raw_data)
        
        # Шаг 4: преобразование в нашу модель
        metadata = self._structured_data.get("metadata", {})
        self._current_document = Document(
            title=metadata.get("title", os.path.basename(file_path)),
            author=metadata.get("author", "Unknown"),
            content=self._structured_data.get("text", ""),
            pages=self._structured_data.get("pages", 0),
            format="PDF"
        )
        
        return self._current_document
    
    def get_metadata(self) -> Dict[str, Any]:
        if self._current_document:
            return {
                "title": self._current_document.title,
                "author": self._current_document.author,
                "pages": self._current_document.pages,
                "format": self._current_document.format
            }
        return {}
    
    def get_text(self) -> str:
        if self._current_document:
            return self._current_document.content
        return ""


# ---------- НАТИВНЫЕ ПАРСЕРЫ (без адаптера) ----------
class TXTParser(DocumentParser):
    """Парсер для текстовых файлов"""
    
    def __init__(self):
        self._document: Optional[Document] = None
    
    def parse(self, file_path: str) -> Document:
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
            
            self._document = Document(
                title=os.path.basename(file_path),
                author="Unknown",
                content=content,
                pages=content.count('\n') // 50 + 1,
                format="TXT"
            )
            return self._document
        except FileNotFoundError:
            raise ValueError(f"File not found: {file_path}")
    
    def get_metadata(self) -> Dict[str, Any]:
        if self._document:
            return {
                "title": self._document.title,
                "author": self._document.author,
                "pages": self._document.pages,
                "format": self._document.format
            }
        return {}
    
    def get_text(self) -> str:
        return self._document.content if self._document else ""


class DOCXParser(DocumentParser):
    """Парсер для DOCX файлов (упрощённая версия)"""
    
    def __init__(self):
        self._document: Optional[Document] = None
    
    def parse(self, file_path: str) -> Document:
        # В реальном коде здесь была бы библиотека python-docx
        print(f"[DOCXParser] Чтение файла {file_path}")
        
        self._document = Document(
            title=os.path.basename(file_path).replace('.docx', ''),
            author="Docx Author",
            content="Sample DOCX content",
            pages=3,
            format="DOCX"
        )
        return self._document
    
    def get_metadata(self) -> Dict[str, Any]:
        if self._document:
            return {
                "title": self._document.title,
                "author": self._document.author,
                "pages": self._document.pages,
                "format": self._document.format
            }
        return {}
    
    def get_text(self) -> str:
        return self._document.content if self._document else ""


# ============================================================
# ЧАСТЬ 2: ФАБРИЧНЫЙ МЕТОД (Factory Method Pattern)
# ============================================================

class DocumentParserFactory(ABC):
    """Абстрактный создатель (Factory Method)"""
    
    @abstractmethod
    def create_parser(self) -> DocumentParser:
        """Фабричный метод для создания парсера"""
        pass
    
    def parse_document(self, file_path: str) -> Document:
        """Шаблонный метод, использующий фабричный метод"""
        parser = self.create_parser()
        return parser.parse(file_path)


class TXTParserFactory(DocumentParserFactory):
    """Фабрика для создания TXT парсера"""
    
    def create_parser(self) -> DocumentParser:
        return TXTParser()


class DOCXParserFactory(DocumentParserFactory):
    """Фабрика для создания DOCX парсера"""
    
    def create_parser(self) -> DocumentParser:
        return DOCXParser()


class PDFParserFactory(DocumentParserFactory):
    """Фабрика для создания PDF парсера (с использованием адаптера)"""
    
    def __init__(self, license_key: str = "DEMO_KEY_12345"):
        self.license_key = license_key
    
    def create_parser(self) -> DocumentParser:
        external_processor = ExternalPDFProcessor(self.license_key)
        return PDFAdapter(external_processor)


# ============================================================
# ЧАСТЬ 3: РАСШИРЯЕМАЯ ФАБРИКА (РЕГИСТРАЦИЯ ТИПОВ)
# ============================================================

class DocumentProcessor:
    """
    Основной класс для обработки документов.
    Поддерживает динамическую регистрацию новых типов документов.
    """
    
    def __init__(self):
        self._factories: Dict[str, DocumentParserFactory] = {}
        self._register_default_factories()
    
    def _register_default_factories(self):
        """Регистрация фабрик по умолчанию"""
        self.register_factory("txt", TXTParserFactory())
        self.register_factory("docx", DOCXParserFactory())
        self.register_factory("pdf", PDFParserFactory())
    
    def register_factory(self, extension: str, factory: DocumentParserFactory):
        """Регистрация новой фабрики для расширения форматов"""
        self._factories[extension.lower()] = factory
        print(f"Зарегистрирована фабрика для .{extension}")
    
    def process_document(self, file_path: str) -> Document:
        """Обработка документа на основе расширения файла"""
        extension = os.path.splitext(file_path)[1][1:].lower()
        
        if extension not in self._factories:
            raise ValueError(f"Unsupported file type: .{extension}")
        
        factory = self._factories[extension]
        return factory.parse_document(file_path)
    
    def get_supported_formats(self) -> List[str]:
        """Возвращает список поддерживаемых форматов"""
        return list(self._factories.keys())


# ============================================================
# ЧАСТЬ 4: ПРИМЕР РАСШИРЕНИЯ (НОВЫЙ ФОРМАТ)
# ============================================================

class JSONParser(DocumentParser):
    """Парсер для JSON файлов"""
    
    def __init__(self):
        self._document: Optional[Document] = None
    
    def parse(self, file_path: str) -> Document:
        import json
        with open(file_path, 'r', encoding='utf-8') as f:
            data = json.load(f)
        
        self._document = Document(
            title=data.get("title", os.path.basename(file_path)),
            author=data.get("author", "Unknown"),
            content=json.dumps(data, indent=2, ensure_ascii=False),
            pages=1,
            format="JSON"
        )
        return self._document
    
    def get_metadata(self) -> Dict[str, Any]:
        if self._document:
            return {
                "title": self._document.title,
                "author": self._document.author,
                "pages": self._document.pages,
                "format": self._document.format
            }
        return {}
    
    def get_text(self) -> str:
        return self._document.content if self._document else ""


class JSONParserFactory(DocumentParserFactory):
    """Фабрика для JSON парсера"""
    
    def create_parser(self) -> DocumentParser:
        return JSONParser()


