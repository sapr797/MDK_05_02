6.1. Пример: объединение CSV и JSON
python
"""
etl_merge.py — Объединение данных из CSV и JSON.
"""

import csv
import json
from pathlib import Path
from datetime import datetime


def extract_csv_users(csv_path):
    """Извлечение пользователей из CSV."""
    users = {}
    with open(csv_path, 'r', encoding='utf-8') as f:
        reader = csv.DictReader(f)
        for row in reader:
            user_id = int(row['id'])
            users[user_id] = {
                'id': user_id,
                'name': row['name'],
                'email': row['email']
            }
    print(f"Извлечено {len(users)} пользователей из CSV")
    return users


def extract_json_orders(json_path):
    """Извлечение заказов из JSON."""
    with open(json_path, 'r', encoding='utf-8') as f:
        data = json.load(f)
    
    orders = data.get('orders', [])
    print(f"Извлечено {len(orders)} заказов из JSON")
    return orders


def transform_merge(users, orders):
    """Объединение пользователей и заказов."""
    merged = []
    
    for order in orders:
        user_id = order.get('user_id')
        user = users.get(user_id, {})
        
        merged_order = {
            'order_id': order.get('id'),
            'order_date': order.get('created_at'),
            'total': order.get('total', 0),
            'user_id': user_id,
            'user_name': user.get('name', 'Unknown'),
            'user_email': user.get('email', 'unknown@example.com')
        }
        merged.append(merged_order)
    
    print(f"Создано {len(merged)} объединённых записей")
    return merged


def load_merged_data(data, output_csv, output_json):
    """Загрузка объединённых данных в CSV и JSON."""
    # Загрузка в CSV
    if data:
        with open(output_csv, 'w', encoding='utf-8', newline='') as f:
            writer = csv.DictWriter(f, fieldnames=data[0].keys())
            writer.writeheader()
            writer.writerows(data)
    
    # Загрузка в JSON
    output = {
        'timestamp': datetime.now().isoformat(),
        'total_records': len(data),
        'records': data
    }
    
    with open(output_json, 'w', encoding='utf-8') as f:
        json.dump(output, f, indent=2, ensure_ascii=False)
    
    print(f"Данные загружены в {output_csv} и {output_json}")


def main():
    """Основная ETL-функция."""
    print("=" * 50)
    print("ETL: ОБЪЕДИНЕНИЕ ДАННЫХ")
    print("=" * 50)
    
    # ETL Pipeline
    users = extract_csv_users('data/users.csv')
    orders = extract_json_orders('data/orders.json')
    merged = transform_merge(users, orders)
    load_merged_data(merged, 'output/merged_orders.csv', 'output/merged_orders.json')
    
    print("\n✅ ETL процесс завершён успешно!")


if __name__ == "__main__":
    main()
