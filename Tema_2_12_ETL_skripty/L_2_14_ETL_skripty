def read_csv_as_lists(filepath):
    data = []
    with open(filepath, 'r', encoding='utf-8') as f:
        reader = csv.reader(f)
        headers = next(reader)  # первая строка — заголовки
        for row in reader:
            data.append(row)
    return headers, data

