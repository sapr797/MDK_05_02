def process_csv_employees(filepath):
    """Обработка CSV файла с данными сотрудников."""
    
    # Extract
    with open(filepath, 'r', encoding='utf-8') as f:
        reader = csv.DictReader(f)
        employees = list(reader)
    
    print(f"Извлечено {len(employees)} записей")
    
    # Transform
    processed = []
    for emp in employees:
        # Преобразование возраста в int
        emp['age'] = int(emp['age'])
        
        # Нормализация email
        emp['email'] = emp['email'].lower().strip()
        
        # Вычисление зарплаты за год
        if 'salary' in emp and emp['salary']:
            emp['annual_salary'] = int(emp['salary']) * 12
        
        # Фильтрация (только совершеннолетние)
        if emp['age'] >= 18:
            processed.append(emp)
    
    print(f"После преобразования: {len(processed)} записей")
    
    # Load
    output_path = filepath.replace('.csv', '_processed.csv')
