def process_json_orders(filepath):
    """Обработка JSON файла с заказами."""
    
    # Extract
    with open(filepath, 'r', encoding='utf-8') as f:
        data = json.load(f)
    
    orders = data.get('orders', [])
    print(f"Извлечено {len(orders)} заказов")
    
    # Transform
    processed = []
    for order in orders:
        # Вычисление суммы заказа
        total = 0
        for item in order.get('items', []):
            price = item.get('price', 0)
            quantity = item.get('quantity', 0)
            total += price * quantity
        
        # Добавление вычисленного поля
        order['total_amount'] = total
        
        # Нормализация статуса
        status = order.get('status', 'unknown').lower()
        order['status'] = status
        
        # Преобразование даты (если есть)
        if 'created_at' in order:
            from datetime import datetime
            order['created_date'] = datetime.fromisoformat(order['created_at']).date().isoformat()
        
        # Фильтрация (только выполненные заказы)
        if order['status'] in ['completed', 'delivered']:
            processed.append(order)
    
    print(f"После преобразования: {len(processed)} заказов")
    
    # Load
    output = {
        'processed_orders': processed,
        'statistics': {
            'total_orders': len(orders),
            'processed_orders': len(processed),
            'total_revenue': sum(o['total_amount'] for o in processed)
        }
    }
    
    output_path = filepath.replace('.json', '_processed.json')
    with open(output_path, 'w', encoding='utf-8') as f:
        json.dump(output, f, indent=2, ensure_ascii=False)
    
    print(f"Результат сохранён в {output_path}")
    return output
