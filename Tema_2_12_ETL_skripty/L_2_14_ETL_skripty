def flatten_json(data, parent_key='', sep='_'):
    """
    Преобразует вложенный JSON в плоский словарь.
    
    Пример:
        {"user": {"name": "Иван", "age": 25}}
        → {"user_name": "Иван", "user_age": 25}
    """
    items = []
    for k, v in data.items():
        new_key = f"{parent_key}{sep}{k}" if parent_key else k
        if isinstance(v, dict):
            items.extend(flatten_json(v, new_key, sep=sep).items())
        else:
            items.append((new_key, v))
    return dict(items)


def extract_nested_values(data, path):
    """
    Извлекает значение по пути в JSON.
    
    Args:
        data: JSON объект
        path: список ключей/индексов
    """
    current = data
    for key in path:
        if isinstance(current, dict):
            current = current.get(key)
        elif isinstance(current, list):
            current = current[key] if isinstance(key, int) else None
        else:
            return None
    return current


