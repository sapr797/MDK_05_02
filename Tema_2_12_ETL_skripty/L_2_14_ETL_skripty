def transform_data(raw_data):
    transformed = []
    
    for record in raw_data:
        # Очистка
        if not record.get('name'):
            continue
        
        # Нормализация
        record['email'] = record.get('email', '').lower().strip()
        
        # Преобразование типов
        if 'age' in record:
            record['age'] = int(record['age'])
        
        # Добавление вычисляемых полей
