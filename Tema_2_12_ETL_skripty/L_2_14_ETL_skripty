"""
etl_aggregate.py — Агрегация данных из CSV.
"""

import csv
from collections import defaultdict
from datetime import datetime


def extract_sales_data(csv_path):
    """Извлечение данных о продажах."""
    sales = []
    with open(csv_path, 'r', encoding='utf-8') as f:
        reader = csv.DictReader(f)
        for row in reader:
            sales.append({
                'date': row['date'],
                'product': row['product'],
                'category': row['category'],
                'quantity': int(row['quantity']),
                'price': float(row['price'])
            })
    return sales


def transform_aggregate(sales):
    """Агрегация данных по различным измерениям."""
    
    # Агрегация по категориям
    category_stats = defaultdict(lambda: {'quantity': 0, 'revenue': 0})
    
    # Агрегация по месяцам
    monthly_stats = defaultdict(lambda: {'quantity': 0, 'revenue': 0})
    
    # Агрегация по продуктам
    product_stats = defaultdict(lambda: {'quantity': 0, 'revenue': 0})
    
    for sale in sales:
        revenue = sale['quantity'] * sale['price']
        
        # По категориям
        category_stats[sale['category']]['quantity'] += sale['quantity']
        category_stats[sale['category']]['revenue'] += revenue
        
        # По продуктам
        product_stats[sale['product']]['quantity'] += sale['quantity']
        product_stats[sale['product']]['revenue'] += revenue
        
        # По месяцам
        month = sale['date'][:7]  # YYYY-MM
        monthly_stats[month]['quantity'] += sale['quantity']
        monthly_stats[month]['revenue'] += revenue
    
    return {
        'by_category': dict(category_stats),
        'by_product': dict(product_stats),
        'by_month': dict(monthly_stats),
        'total': {
            'quantity': sum(s['quantity'] for s in sales),
            'revenue': sum(s['quantity'] * s['price'] for s in sales)
        }
    }


def load_aggregated_data(aggregated, output_path):
    """Загрузка агрегированных данных."""
    with open(output_path, 'w', encoding='utf-8') as f:
        json.dump(aggregated, f, indent=2, ensure_ascii=False)
    
    print(f"Агрегированные данные сохранены в {output_path}")


def main():
    sales = extract_sales_data('data/sales.csv')
    aggregated = transform_aggregate(sales)
    load_aggregated_data(aggregated, 'output/sales_aggregated.json')
    
    # Вывод статистики
    print("\n📊 СТАТИСТИКА ПРОДАЖ:")
    print(f"   Всего продаж: {len(sales)}")
    print(f"   Общее количество: {aggregated['total']['quantity']}")
    print(f"   Общая выручка: {aggregated['total']['revenue']:.2f}")
    print(f"\n   Категории: {', '.join(aggregated['by_category'].keys())}")
